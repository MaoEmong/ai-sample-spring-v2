{{> layout/header}}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">회 원 가 입</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/join" method="post" onsubmit="return validateForm()">
                        <!-- 아이디 입력 및 중복 체크 -->
                        <div class="mb-4">
                            <label for="username" class="form-label fw-bold">아이디</label>
                            <div class="input-group">
                                <input type="text" class="form-control" id="username" name="username" 
                                       placeholder="4~20자 이내로 입력하세요" required>
                                <button type="button" class="btn btn-outline-primary" onclick="checkUsername()">중복체크</button>
                            </div>
                            <div id="username-msg" class="small mt-1"></div>
                        </div>

                        <!-- 비밀번호 입력 -->
                        <div class="mb-4">
                            <label for="password" class="form-label fw-bold">비밀번호</label>
                            <input type="password" class="form-control" id="password" name="password" 
                                   placeholder="4~20자 이내로 입력하세요" required>
                            <div id="password-msg" class="small mt-1"></div>
                        </div>

                        <!-- 이메일 입력 -->
                        <div class="mb-4">
                            <label for="email" class="form-label fw-bold">이메일</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   placeholder="example@email.com" required>
                            <div id="email-msg" class="small mt-1"></div>
                        </div>

                        <!-- 가입 버튼 -->
                        <div class="d-grid mt-5">
                            <button id="btn-submit" type="submit" class="btn btn-primary btn-lg" disabled>가입하기</button>
                        </div>
                    </form>
                </div>
                <div class="card-footer text-center py-3 bg-light">
                    <span class="text-muted">이미 계정이 있으신가요?</span>
                    <a href="/login-form" class="text-primary text-decoration-none fw-bold ms-1">로그인</a>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let isUsernameValid = false;
    let isPasswordValid = false;
    let isEmailValid = false;

    // 폼 상태 체크하여 버튼 활성화/비활성화
    function updateSubmitButton() {
        const btnSubmit = document.querySelector("#btn-submit");
        btnSubmit.disabled = !(isUsernameValid && isPasswordValid && isEmailValid);
    }

    // 아이디 중복 체크 (AJAX)
    async function checkUsername() {
        const username = document.querySelector("#username").value;
        const msg = document.querySelector("#username-msg");

        if (!username || username.length < 4) {
            msg.innerText = "아이디는 4자 이상이어야 합니다.";
            msg.className = "small mt-1 text-danger";
            isUsernameValid = false;
            updateSubmitButton();
            return;
        }

        try {
            const response = await fetch(`/api/user/username-same-check?username=${username}`);
            const result = await response.json();

            if (result.body === true) {
                msg.innerText = "이미 사용 중인 아이디입니다.";
                msg.className = "small mt-1 text-danger";
                isUsernameValid = false;
            } else {
                msg.innerText = "사용 가능한 아이디입니다.";
                msg.className = "small mt-1 text-success";
                isUsernameValid = true;
            }
        } catch (error) {
            console.error("Error checking username:", error);
            msg.innerText = "중복 체크 중 오류가 발생했습니다.";
            msg.className = "small mt-1 text-danger";
            isUsernameValid = false;
        }
        updateSubmitButton();
    }

    // 비밀번호 실시간 유효성 검사
    document.querySelector("#password").addEventListener("input", function() {
        const password = this.value;
        const msg = document.querySelector("#password-msg");

        if (password.length < 4 || password.length > 20) {
            msg.innerText = "비밀번호는 4~20자여야 합니다.";
            msg.className = "small mt-1 text-danger";
            isPasswordValid = false;
        } else {
            msg.innerText = "사용 가능한 비밀번호입니다.";
            msg.className = "small mt-1 text-success";
            isPasswordValid = true;
        }
        updateSubmitButton();
    });

    // 이메일 실시간 유효성 검사
    document.querySelector("#email").addEventListener("input", function() {
        const email = this.value;
        const msg = document.querySelector("#email-msg");
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!emailRegex.test(email)) {
            msg.innerText = "올바른 이메일 형식이 아닙니다.";
            msg.className = "small mt-1 text-danger";
            isEmailValid = false;
        } else {
            msg.innerText = "사용 가능한 이메일입니다.";
            msg.className = "small mt-1 text-success";
            isEmailValid = true;
        }
        updateSubmitButton();
    });

    // 아이디 변경 시 상태 초기화 (재검사 유도)
    document.querySelector("#username").addEventListener("input", function() {
        isUsernameValid = false;
        document.querySelector("#username-msg").innerText = "아이디 중복 체크가 필요합니다.";
        document.querySelector("#username-msg").className = "small mt-1 text-warning";
        updateSubmitButton();
    });

    // 최종 폼 전송 전 검증
    function validateForm() {
        if (!(isUsernameValid && isPasswordValid && isEmailValid)) {
            alert("모든 필드를 올바르게 입력해주세요.");
            return false;
        }
        return true;
    }
</script>

{{> layout/footer}}
