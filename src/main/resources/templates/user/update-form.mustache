{{> layout/header}}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white text-center py-3">
                    <h4 class="mb-0">마이페이지 / 정보수정</h4>
                </div>
                <div class="card-body p-4">
                    <form action="/user/update" method="post" id="update-form">
                        <!-- 아이디 입력 (수정 불가) -->
                        <div class="mb-4">
                            <label for="username" class="form-label fw-bold">아이디</label>
                            <input type="text" class="form-control" id="username" name="username" 
                                   value="{{sessionUser.username}}" readonly>
                        </div>

                        <!-- 비밀번호 입력 -->
                        <div class="mb-4">
                            <label for="password" class="form-label fw-bold">새 비밀번호</label>
                            <input type="password" class="form-control" id="password" name="password" 
                                   placeholder="4~20자 이내로 입력하세요" required>
                            <div id="password-msg" class="small mt-1"></div>
                        </div>

                        <!-- 이메일 입력 -->
                        <div class="mb-4">
                            <label for="email" class="form-label fw-bold">이메일</label>
                            <input type="email" class="form-control" id="email" name="email" 
                                   value="{{sessionUser.email}}" required>
                            <div id="email-msg" class="small mt-1"></div>
                        </div>

                        <!-- 버튼들 -->
                        <div class="d-flex justify-content-between mt-5">
                            <button id="btn-submit" type="submit" class="btn btn-primary btn-lg w-50 me-2" disabled>수정하기</button>
                            <button type="button" class="btn btn-danger btn-lg w-50 ms-2" onclick="deleteAccount()">회원탈퇴</button>
                        </div>
                    </form>
                    
                    <form action="/user/delete" method="post" id="delete-form" style="display: none;">
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    let isPasswordValid = false;
    let isEmailValid = true; // 기본적으로 기존 이메일이 유효함

    function updateSubmitButton() {
        const btnSubmit = document.querySelector("#btn-submit");
        btnSubmit.disabled = !(isPasswordValid && isEmailValid);
    }

    // 비밀번호 실시간 유효성 검사
    document.querySelector("#password").addEventListener("input", function() {
        const password = this.value;
        const msg = document.querySelector("#password-msg");

        if (password.length < 4 || password.length > 20) {
            msg.innerText = "비밀번호는 4~20자여야 합니다.";
            msg.className = "small mt-1 text-danger";
            isPasswordValid = false;
        } else {
            msg.innerText = "사용 가능한 비밀번호입니다.";
            msg.className = "small mt-1 text-success";
            isPasswordValid = true;
        }
        updateSubmitButton();
    });

    // 이메일 실시간 유효성 검사
    document.querySelector("#email").addEventListener("input", function() {
        const email = this.value;
        const msg = document.querySelector("#email-msg");
        const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;

        if (!emailRegex.test(email)) {
            msg.innerText = "올바른 이메일 형식이 아닙니다.";
            msg.className = "small mt-1 text-danger";
            isEmailValid = false;
        } else {
            msg.innerText = "사용 가능한 이메일입니다.";
            msg.className = "small mt-1 text-success";
            isEmailValid = true;
        }
        updateSubmitButton();
    });

    function deleteAccount() {
        if (confirm("정말로 회원 탈퇴를 진행하시겠습니까? 삭제된 데이터는 복구할 수 없습니다.")) {
            document.getElementById('delete-form').submit();
        }
    }
</script>

{{> layout/footer}}
